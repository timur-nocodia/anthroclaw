# ─── Anthropic auth (pick ONE) ────────────────────────────────────────
# Recommended for Docker / headless: long-lived OAuth token from
# `claude setup-token` (run on host with Claude Code CLI installed).
# Uses your Claude Max/Pro subscription, ~1 year lifetime.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Alternative: standard API key from console.anthropic.com (pay-as-you-go).
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── Channels ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ─── Optional providers ───────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
ASSEMBLYAI_API_KEY=your-assemblyai-api-key-here
BRAVE_API_KEY=your-brave-search-api-key-here
EXA_API_KEY=your-exa-api-key-here

# ─── Runtime ──────────────────────────────────────────────────────────
LOG_LEVEL=info
TZ=UTC
UI_PORT=3000

# ─── Capability cutoff (v0.8.0) ───────────────────────────────────────
# Canonical paths for the agents and data directories. The cutoff layer
# (`applyCutoffOptions`) resolves an agent's sandbox cwd via
# `agentWorkspaceDir(agentId)` which falls back to `<process.cwd()>/agents`.
# In Docker setups whose `working_dir` is NOT the repo root (e.g.
# `working_dir: /app/ui` for the Next.js UI), the fallback resolves to a
# path that does NOT exist, and the spawned SDK process fails to start
# with a misleading "Claude Code native binary not found" error.
# Set these explicitly in production to disambiguate.
OC_AGENTS_DIR=/app/agents
OC_DATA_DIR=/app/data

# Master key for the encrypted credential store
# (src/agent/credentials/encrypted-fs-store.ts). 32 bytes / 64 hex chars.
# Generate once with: openssl rand -hex 32
# REQUIRED once any agent uses the credential store (v0.9.0+); set now to
# avoid surprise at the v0.9 deploy.
ANTHROCLAW_MASTER_KEY=
